#!/usr/bin/env bash
set -euo pipefail

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT
cat > "$tmp"

jq --slurpfile cur "$tmp" '
  . as $managed
  | $cur[0] as $current
  | .active_profile = ($current.active_profile // $managed.active_profile)
  | .profiles.personal.last_synced = ($current.profiles.personal.last_synced // .profiles.personal.last_synced)
' <<'JSON'
{
  "active_profile": "personal",
  "profiles": {
    "personal": {
      "name": "personal",
      "mcp_servers": {
        "airis-mcp-gateway": "sse",
        "chrome-devtools": "npx",
        "cloudflare-docs": "npx",
        "cloudflare": "npx",
        "context7": "npx",
        "terraform-claude-code": "custom",
        "terraform-windsurf": "custom",
        "terraform-codex": "custom",
        "github-mcp-server-codex": "custom",
        "fetch": "uvx",
        "filesystem": "npx",
        "git": "uvx",
        "magic": "npx",
        "mcp-playwright": "npx",
        "memory": "npx",
        "morphllm": "npx",
        "sequential-thinking": "npx",
        "server-puppeteer": "custom",
        "tavily": "npx",
        "time": "uvx"
      },
      "agents": {
        "claude-code": {
          "enabled": true,
          "mcp_scope": "local"
        },
        "windsurf": {
          "enabled": true,
          "mcp_scope": "local"
        },
        "codex": {
          "enabled": true,
          "mcp_scope": "local"
        }
      },
      "agent_overrides": {
        "windsurf": {
          "airis-mcp-gateway": "npx"
        }
      },
      "agent_exclusions": {
        "claude-code": [
          "mcp-playwright",
          "terraform-codex",
          "terraform-windsurf",
          "github-mcp-server-codex",
          "context7",
          "tavily",
          "chrome-devtools",
          "morphllm",
          "magic"
        ],
        "codex": [
          "airis-mcp-gateway",
          "terraform-claude-code",
          "terraform-windsurf"
        ],
        "windsurf": [
          "terraform-claude-code",
          "terraform-codex",
          "context7",
          "tavily",
          "chrome-devtools",
          "morphllm",
          "magic",
          "github-mcp-server-codex"
        ]
