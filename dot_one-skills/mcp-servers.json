{
  "servers": {
    "airis-mcp-gateway": {
      "description": "AIRIS MCP Gateway",
      "transports": {
        "sse": {
          "type": "sse",
          "url": "http://192.168.86.53:9400/sse"
        },
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "mcp-remote@latest",
            "http://192.168.86.53:9400/sse",
            "--transport",
            "sse-only",
            "--allow-http"
          ]
        }
      }
    },
    "mcp-playwright": {
      "description": "Imported from Windsurf (npx)",
      "transports": {
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "@playwright/mcp@latest"
          ]
        }
      }
    },
    "terraform": {
      "description": "Imported from Windsurf (docker)",
      "transports": {
        "docker": {
          "type": "stdio",
          "command": "podman",
          "args": [
            "run",
            "-i",
            "--name",
            "terraform-mcp-server",
            "--rm",
            "hashicorp/terraform-mcp-server"
          ]
        }
      }
    },
    "cloudflare-docs": {
      "description": "Search the Cloudflare documentation.",
      "transports": {
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "mcp-remote",
            "https://docs.mcp.cloudflare.com/mcp"
          ]
        }
      }
    }
  }
}
