{
  "servers": {
    "airis-mcp-gateway": {
      "description": "AIRIS MCP Gateway",
      "transports": {
        "sse": {
          "type": "sse",
          "url": "http://192.168.86.53:9400/sse"
        },
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "mcp-remote@latest",
            "http://192.168.86.53:9400/sse",
            "--transport",
            "sse-only",
            "--allow-http"
          ]
        }
      }
    },
    "mcp-playwright": {
      "description": "Imported from Windsurf (npx)",
      "transports": {
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "@playwright/mcp@latest"
          ]
        }
      }
    },
    "terraform-windsurf": {
      "description": "terraform MCP server for Windsurf (custom)",
      "transports": {
        "custom": {
          "type": "stdio",
          "command": "$HOME/.config/bin/utilities/terraform_mcp.sh",
          "args": [
            "windsurf"
          ]
        }
      }
    },
    "terraform-codex": {
      "description": "terraform MCP server for Codex (custom)",
      "transports": {
        "custom": {
          "type": "stdio",
          "command": "$HOME/.config/bin/utilities/terraform_mcp.sh",
          "args": [
            "codex"
          ]
        }
      }
    },
    "terraform-claude-code": {
      "description": "terraform MCP server for Claude (custom)",
      "transports": {
        "custom": {
          "type": "stdio",
          "command": "$HOME/.config/bin/utilities/terraform_mcp.sh",
          "args": [
            "claude"
          ]
        }
      }
    },
    "terraform-cursor": {
      "description": "terraform MCP server for Cursor (custom)",
      "transports": {
        "custom": {
          "type": "stdio",
          "command": "$HOME/.config/bin/utilities/terraform_mcp.sh",
          "args": [
            "cursor"
          ]
        }
      }
    },
    "cloudflare": {
      "description": "Cloudflare MCP server",
      "transports": {
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "@cloudflare/mcp-server-cloudflare@latest",
            "run"
          ],
          "env": {
            "CLOUDFLARE_ACCOUNT_ID": "{{ onepasswordRead "op://Personal/cloudflare/account-id" }}",
            "CLOUDFLARE_API_TOKEN": "{{ onepasswordRead "op://Personal/cloudflare/read-all-token" }}"
          }
        }
      }
    },
    "cloudflare-docs": {
      "description": "Search the Cloudflare documentation.",
      "transports": {
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "mcp-remote",
            "https://docs.mcp.cloudflare.com/mcp"
          ]
        }
      }
    },
    "atlassian-mcp-server": {
      "description": "Imported from Cursor (sse)",
      "transports": {
        "sse": {
          "type": "sse",
          "url": "https://mcp.atlassian.com/v1/sse"
        }
      }
    },
    "github-mcp-server-windsurf": {
      "description": "Imported from Windsurf (custom)",
      "transports": {
        "custom": {
          "type": "stdio",
          "command": "$HOME/.config/bin/utilities/gh_token_mcp.sh",
          "args": [
            "windsurf"
          ],
          "env": {
            "GITHUB_TOOLSETS": "repos,issues,pull_requests,code_security"
          }
        }
      }
    },
    "github-mcp-server-cursor": {
      "description": "Imported from Cursor (custom)",
      "transports": {
        "custom": {
          "type": "stdio",
          "command": "$HOME/.config/bin/utilities/gh_token_mcp.sh",
          "args": [
            "cursor"
          ],
          "env": {
            "GITHUB_TOOLSETS": "repos,issues,pull_requests,code_security"
          }
        }
      }
    },
    "github-mcp-server-claude-code": {
      "description": "Imported from Claude Code (custom)",
      "transports": {
        "custom": {
          "type": "stdio",
          "command": "$HOME/.config/bin/utilities/gh_token_mcp.sh",
          "args": [
            "claude-code"
          ],
          "env": {
            "GITHUB_TOOLSETS": "repos,issues,pull_requests,code_security"
          }
        }
      }
    },
    "github-mcp-server-codex": {
      "description": "Imported from Codex (custom)",
      "transports": {
        "custom": {
          "type": "stdio",
          "command": "$HOME/.config/bin/utilities/gh_token_mcp.sh",
          "args": [
            "codex"
          ],
          "env": {
            "GITHUB_TOOLSETS": "repos,issues,pull_requests,code_security"
          }
        }
      }
    },
    "fetch": {
      "description": "Imported from Windsurf (uvx)",
      "transports": {
        "uvx": {
          "type": "stdio",
          "command": "uvx",
          "args": [
            "mcp-server-fetch"
          ]
        }
      }
    },
    "filesystem": {
      "description": "Imported from Windsurf (npx)",
      "transports": {
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "@modelcontextprotocol/server-filesystem",
            "~/DEV",
            "$HOME/ghq",
            "$HOME/DEV"
          ]
        }
      }
    },
    "git": {
      "description": "Imported from Windsurf (uvx)",
      "transports": {
        "uvx": {
          "type": "stdio",
          "command": "uvx",
          "args": [
            "mcp-server-git"
          ]
        }
      }
    },
    "memory": {
      "description": "Imported from Windsurf (npx)",
      "transports": {
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "@modelcontextprotocol/server-memory"
          ],
          "env": {
            "MEMORY_FILE_PATH": ""
          }
        }
      }
    },
    "postgresql": {
      "description": "Imported from Windsurf (npx)",
      "transports": {
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "@modelcontextprotocol/server-postgres",
            "{{ onepasswordRead "op://Personal/cse-prod-rds-conn/credential" }}"
          ]
        }
      }
    },
    "rootly": {
      "description": "Imported from Windsurf (uvx)",
      "transports": {
        "uvx": {
          "type": "stdio",
          "command": "uvx",
          "args": [
            "--from",
            "rootly-mcp-server",
            "rootly-mcp-server"
          ],
          "env": {
            "ROOTLY_API_TOKEN": "{{ onepasswordRead "op://Personal/rootly-mcp-server-token/credential" }}"
          }
        }
      }
    },
    "sequential-thinking": {
      "description": "Imported from Windsurf (npx)",
      "transports": {
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "@modelcontextprotocol/server-sequential-thinking"
          ]
        }
      }
    },
    "time": {
      "description": "Imported from Windsurf (uvx)",
      "transports": {
        "uvx": {
          "type": "stdio",
          "command": "uvx",
          "args": [
            "mcp-server-time"
          ]
        }
      }
    },
    "context7": {
      "description": "Imported from Windsurf (sse)",
      "transports": {
        "sse": {
          "type": "sse",
          "url": "https://mcp.context7.com/mcp",
          "headers": {
            "CONTEXT7_API_KEY": "{{ onepasswordRead "op://Personal/Context7/api-key" }}"
          }
        },
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "mcp-remote",
            "https://mcp.context7.com/mcp"
          ],
          "env": {
            "CONTEXT7_API_KEY": "{{ onepasswordRead "op://Personal/Context7/api-key" }}"
          }
        }
      }
    },
    "tavily": {
      "description": "Imported from Airis Gateway",
      "transports": {
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "mcp-remote",
            "https://mcp.tavily.com/mcp/?tavilyApiKey={{ onepasswordRead "op://Personal/Tavily/api-key" }}"
          ]
        }
      }
    },
    "chrome-devtools": {
      "description": "Imported from Airis Gateway",
      "transports": {
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "chrome-devtools-mcp@latest"
          ]
        }
      }
    },
    "morphllm": {
      "description": "Imported from Airis Gateway",
      "transports": {
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "@morphllm/morphmcp"
          ],
          "env": {
            "MORPH_API_KEY": "{{ onepasswordRead "op://Personal/Morphllm/demo-api-key" }}",
            "ENABLED_TOOLS": "edit_file,warpgrep_codebase_search"
          }
        }
      }
    },
    "magic": {
      "description": "Imported from Airis Gateway",
      "transports": {
        "npx": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "@21st-dev/magic@latest"
          ],
          "env": {
            "API_KEY": "{{ onepasswordRead "op://Personal/magic-mcp/dev-api-key" }}"
          }
        }
      }
    },
    "server-puppeteer": {
      "description": "Imported from Claude Code (stdio)",
      "transports": {
        "custom": {
          "type": "stdio",
          "command": "$HOME/.local/state/fnm_multishells/91001_1754413218977/bin/node",
          "args": [
            "$HOME/Library/Application Support/fnm/node-versions/v21.1.0/installation/lib/node_modules/@modelcontextprotocol/server-puppeteer/dist/index.js"
          ]
        }
      }
    }
  }
}
